#!/usr/bin/env bash
# OpenSpec-extended - Installer for OpenSpec resources
# Usage: openspec-extended <install|update> <tool> [--with-core]

set -euo pipefail

readonly SCRIPT_NAME="openspec-extended"
readonly SCRIPT_VERSION="1.0.1"

readonly COLOR_GREEN='\033[0;32m'
readonly COLOR_RED='\033[0;31m'
readonly COLOR_YELLOW='\033[0;33m'
readonly COLOR_RESET='\033[0m'

declare -A TOOL_DIRS=(["opencode"]=".opencode" ["claude"]=".claude")

SCRIPT_SOURCE="${BASH_SOURCE[0]:-$0}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
readonly SCRIPT_DIR

RESOURCES_DIR=""

log_success() { echo -e "${COLOR_GREEN}✓${COLOR_RESET} $*"; }
log_info()    { echo -e "→ $*"; }
log_error()   { echo -e "${COLOR_RED}✗${COLOR_RESET} $*" >&2; }
log_warn()    { echo -e "${COLOR_YELLOW}!${COLOR_RESET} $*"; }

resolve_resources_dir() {
    if [[ -d "$SCRIPT_DIR/../resources" ]]; then
        RESOURCES_DIR="$(cd "$SCRIPT_DIR/../resources" && pwd)"
        return 0
    fi
    
    local xdg_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
    if [[ -d "$xdg_data_home/openspec-extended/resources" ]]; then
        RESOURCES_DIR="$xdg_data_home/openspec-extended/resources"
        return 0
    fi
    
    log_error "Cannot find resources directory"
    log_error "  Checked: $SCRIPT_DIR/../resources"
    log_error "  Checked: $xdg_data_home/openspec-extended/resources"
    exit 1
}

get_tool_dir() {
    local tool="$1"
    if [[ -z "${TOOL_DIRS[$tool]:-}" ]]; then
        return 1
    fi
    echo "${TOOL_DIRS[$tool]}"
}

show_version() {
    echo "$SCRIPT_NAME $SCRIPT_VERSION"
}

show_help() {
    cat << EOF
$SCRIPT_NAME - Installer for OpenSpec resources

Usage:
  $SCRIPT_NAME <command> <tool> [options]
  $SCRIPT_NAME run <change-id> [options]
  $SCRIPT_NAME --version
  $SCRIPT_NAME --help

Commands:
  install <tool>  Install/update resources (version-aware)
  update <tool>   Force update all resources (overwrite existing)
  run             Run autonomous implementation workflow

Available tools:
  opencode        Install to .opencode/ directory
  claude          Install to .claude/ directory

Options:
  --with-core     Also deploy core OpenSpec skills (osc-*)
  --version       Show version
  --help          Show this help message

Run '$SCRIPT_NAME run --help' for workflow options.

Examples:
  $SCRIPT_NAME install opencode
  $SCRIPT_NAME install opencode --with-core
  $SCRIPT_NAME update claude
  $SCRIPT_NAME run my-change -v
EOF
}

show_usage() {
    log_error "Usage: $SCRIPT_NAME <command> <tool> [--with-core]"
    log_error "       $SCRIPT_NAME run <change-id> [options]"
    echo
    echo "Commands:"
    echo "  install <tool>  Install/update resources (version-aware)"
    echo "  update <tool>   Force update all resources"
    echo "  run             Run autonomous implementation workflow"
    echo
    echo "Available tools: opencode, claude"
    echo
    echo "Run '$SCRIPT_NAME --help' for more information."
}

parse_version() {
    local v="$1"
    if [[ ! "$v" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        echo "0 0 0"
        return
    fi
    echo "${v//./ }"
}

compare_versions() {
    local v1="$1" v2="$2"
    
    if [[ -z "$v1" ]] || [[ -z "$v2" ]]; then
        echo "0"
        return
    fi
    
    read -ra p1 <<< "$(parse_version "$v1")"
    read -ra p2 <<< "$(parse_version "$v2")"
    
    for i in 0 1 2; do
        local n1="${p1[$i]:-0}"
        local n2="${p2[$i]:-0}"
        if (( n1 > n2 )); then
            echo "1"
            return
        elif (( n1 < n2 )); then
            echo "-1"
            return
        fi
    done
    echo "0"
}

get_installed_version() {
    local manifest="$1" type="$2" name="$3"
    
    if [[ ! -f "$manifest" ]]; then
        echo ""
        return
    fi
    
    jq -r ".resources.$type.\"$name\".version // empty" "$manifest" 2>/dev/null || echo ""
}

should_deploy() {
    local name="$1" source_version="$2" target_path="$3" target_manifest="$4" type="$5" force="$6"
    
    if [[ "$force" == "true" ]]; then
        echo "update"
        return
    fi
    
    if [[ ! -e "$target_path" ]]; then
        echo "install"
        return
    fi
    
    local installed
    installed=$(get_installed_version "$target_manifest" "$type" "$name")
    
    if [[ -z "$installed" ]]; then
        echo "install"
        return
    fi
    
    local cmp
    cmp=$(compare_versions "$source_version" "$installed")
    
    if [[ "$cmp" == "1" ]]; then
        echo "upgrade"
    else
        echo "skip"
    fi
}

get_target_path() {
    local type="$1" target_dir="$2" name="$3"
    
    case "$type" in
        skills)   echo "$target_dir/skills/$name" ;;
        commands)
            if [[ -f "$target_dir/commands/${name}.md" ]]; then
                echo "$target_dir/commands/${name}.md"
            else
                for subdir in "$target_dir/commands"/*/; do
                    if [[ -d "$subdir" ]]; then
                        local base_name="${name#osx-}"
                        if [[ -f "$subdir${base_name}.md" ]]; then
                            echo "$subdir${base_name}.md"
                            return
                        fi
                    fi
                done
                echo "$target_dir/commands/${name}.md"
            fi
            ;;
        agents)   echo "$target_dir/agents/${name}.md" ;;
        scripts)  echo "$target_dir/scripts/$name" ;;
        lib)      echo "$target_dir/scripts/lib/$name" ;;
    esac
}

deploy_skills() {
    local source_base="$1" target_dir="$2" name="$3"
    local target_skills="$target_dir/skills"
    mkdir -p "$target_skills"
    rm -rf "$target_skills/$name"
    cp -r "$source_base/$name" "$target_skills/"
}

deploy_commands() {
    local source_base="$1" target_dir="$2" name="$3"
    local target_commands="$target_dir/commands"
    mkdir -p "$target_commands"
    
    if [[ -f "$source_base/${name}.md" ]]; then
        cp -f "$source_base/${name}.md" "$target_commands/"
    else
        for subdir in "$source_base"/*/; do
            if [[ -d "$subdir" ]]; then
                local subdir_name
                subdir_name=$(basename "$subdir")
                local base_name="${name#osx-}"
                if [[ -f "$subdir${base_name}.md" ]]; then
                    mkdir -p "$target_commands/$subdir_name"
                    cp -f "$subdir${base_name}.md" "$target_commands/$subdir_name/"
                    return
                fi
            fi
        done
        return 1
    fi
}

deploy_agents() {
    local source_base="$1" target_dir="$2" name="$3"
    local target_agents="$target_dir/agents"
    mkdir -p "$target_agents"
    cp -f "$source_base/${name}.md" "$target_agents/"
}

deploy_scripts() {
    local source_base="$1" target_dir="$2" name="$3"
    local target_scripts="$target_dir/scripts"
    mkdir -p "$target_scripts"
    cp -f "$source_base/$name" "$target_scripts/"
    chmod +x "$target_scripts/$name"
}

deploy_lib() {
    local source_base="$1" target_dir="$2" name="$3"
    local target_lib="$target_dir/scripts/lib"
    mkdir -p "$target_lib"
    cp -f "$source_base/$name" "$target_lib/"
    chmod +x "$target_lib/$name"
}

deploy_type() {
    local type="$1" source_dir="$2" target_dir="$3" target_manifest="$4" source_manifest="$5" force="$6"
    
    local source_type_dir
    case "$type" in
        skills)   source_type_dir="$source_dir/skills" ;;
        commands) source_type_dir="$source_dir/commands" ;;
        agents)   source_type_dir="$source_dir/agents" ;;
        scripts)  source_type_dir="$source_dir/scripts" ;;
        lib)      source_type_dir="$source_dir/scripts/lib" ;;
    esac
    
    if [[ ! -d "$source_type_dir" ]]; then
        return 0
    fi
    
    local resources
    resources=$(jq -r ".resources.$type | keys[] // empty" "$source_manifest" 2>/dev/null) || return 0
    
    if [[ -z "$resources" ]]; then
        return 0
    fi
    
    local count=0
    local skipped=0
    
    for name in $resources; do
        local source_version
        source_version=$(jq -r ".resources.$type.\"$name\".version // empty" "$source_manifest" 2>/dev/null) || continue
        
        if [[ -z "$source_version" ]]; then
            continue
        fi
        
        local target_path
        target_path=$(get_target_path "$type" "$target_dir" "$name")
        
        local decision
        decision=$(should_deploy "$name" "$source_version" "$target_path" "$target_manifest" "$type" "$force")
        
        case "$decision" in
            install|upgrade|update)
                "deploy_$type" "$source_type_dir" "$target_dir" "$name"
                count=$((count + 1))
                ;;
            skip)
                skipped=$((skipped + 1))
                ;;
        esac
    done
    
    DEPLOY_TOTAL=$((DEPLOY_TOTAL + count))
    DEPLOY_SKIPPED=$((DEPLOY_SKIPPED + skipped))
    
    if [[ $count -gt 0 ]]; then
        local type_label="$type"
        if [[ "$type" == "skills" ]] && [[ $count -eq 1 ]]; then
            type_label="skill"
        elif [[ "$type" == "commands" ]] && [[ $count -eq 1 ]]; then
            type_label="command"
        elif [[ "$type" == "agents" ]] && [[ $count -eq 1 ]]; then
            type_label="agent"
        elif [[ "$type" == "scripts" ]] && [[ $count -eq 1 ]]; then
            type_label="script"
        elif [[ "$type" == "lib" ]] && [[ $count -eq 1 ]]; then
            type_label="lib script"
        fi
        log_success "Deployed $count $type_label to $TOOL"
        echo "  Target: ${TARGET_DIR}/${type}/"
    fi
    
    if [[ $skipped -gt 0 ]]; then
        echo "  Skipped $skipped current $type"
    fi
}

deploy_all_resources() {
    local tool="$1" force="$2"
    local source_dir="$RESOURCES_DIR/$tool"
    local source_manifest="$source_dir/manifest.json"
    
    if [[ ! -f "$source_manifest" ]]; then
        log_error "Manifest not found: $source_manifest"
        exit 1
    fi
    
    local source_version
    source_version=$(jq -r '.version' "$source_manifest")
    
    local target_dir
    target_dir="$(pwd)/${TOOL_DIRS[$tool]}"
    local target_manifest="$target_dir/manifest.json"
    
    mkdir -p "$target_dir"
    
    DEPLOY_TOTAL=0
    DEPLOY_SKIPPED=0
    
    for type in skills commands agents scripts lib; do
        deploy_type "$type" "$source_dir" "$target_dir" "$target_manifest" "$source_manifest" "$force"
    done
    
    jq --arg v "$source_version" '.version = $v' "$source_manifest" > "$target_manifest"
    log_success "Manifest updated to v$source_version"
    echo "  Target: $TARGET_DIR/manifest.json"
    
    if [[ $DEPLOY_TOTAL -eq 0 ]] && [[ $DEPLOY_SKIPPED -eq 0 ]]; then
        echo "No resources to deploy"
    elif [[ $DEPLOY_TOTAL -eq 0 ]] && [[ $DEPLOY_SKIPPED -gt 0 ]]; then
        echo "All $DEPLOY_SKIPPED resources are current"
    fi
}

update_gitignore() {
    local gitignore="$(pwd)/.gitignore"
    local marker_start="# BEGIN OpenSpec autonomous workflow state"
    local marker_end="# END OpenSpec autonomous workflow state"
    
    if [[ ! -f "$gitignore" ]]; then
        touch "$gitignore"
    fi
    
    if grep -qF "$marker_start" "$gitignore" 2>/dev/null; then
        return 0
    fi
    
    {
        echo ""
        echo "$marker_start"
        echo ".openspec-baseline.json"
        echo "openspec/changes/*/state.json"
        echo "openspec/changes/*/complete.json"
        echo "openspec/changes/*/iterations.json"
        echo "openspec/changes/*/decision-log.json"
        echo "openspec/changes/*/verification-report.md"
        echo "openspec/changes/*/reflections.md"
        echo "openspec/changes/*/test-compliance-report.md"
        echo "openspec/changes/*/suggestions.md"
        echo ".osx-orchestrate-*.log"
        echo "$marker_end"
    } >> "$gitignore"
    
    log_success "Added OpenSpec state files to .gitignore"
}

rename_core_resources() {
    local tool="$1"
    local target_dir
    target_dir=$(get_tool_dir "$tool")
    
    log_info "Renaming core resources (opsx-* → osc-*, openspec-* → osc-*)..."
    
    local renamed=0
    local cmd_dir="$target_dir/commands"
    
    if [[ -d "$cmd_dir" ]]; then
        while IFS= read -r -d '' cmd_file; do
            local basename
            basename=$(basename "$cmd_file")
            
            if [[ "$basename" =~ ^opsx-(.+)\.md$ ]]; then
                local new_name="osc-${BASH_REMATCH[1]}.md"
                mv "$cmd_file" "$cmd_dir/$new_name"
                renamed=$((renamed + 1))
            fi
        done < <(find "$cmd_dir" -maxdepth 1 -type f -name "*.md" -print0 2>/dev/null)
        
        if [[ -d "$cmd_dir/opsx" ]]; then
            if [[ ! -d "$cmd_dir/osc" ]]; then
                mv "$cmd_dir/opsx" "$cmd_dir/osc"
            else
                mv "$cmd_dir/opsx"/*.md "$cmd_dir/osc/" 2>/dev/null || true
                rmdir "$cmd_dir/opsx" 2>/dev/null || true
            fi
            renamed=$((renamed + 1))
        fi
    fi
    
    if [[ -d "$target_dir/skills" ]]; then
        while IFS= read -r -d '' skill_dir; do
            local basename
            basename=$(basename "$skill_dir")
            local dirname
            dirname=$(dirname "$skill_dir")
            
            if [[ "$basename" =~ ^openspec-(.+)$ ]]; then
                local new_name="osc-${BASH_REMATCH[1]}"
                mv "$skill_dir" "$dirname/$new_name"
                renamed=$((renamed + 1))
            fi
        done < <(find "$target_dir/skills" -mindepth 1 -maxdepth 1 -type d -name "openspec-*" -print0 2>/dev/null)
        
        while IFS= read -r -d '' skill_file; do
            sed -i 's|^name: openspec-|name: osc-|' "$skill_file"
            sed -i 's|/opsx-|/osc-|g' "$skill_file"
            sed -i 's|/opsx:|/osc:|g' "$skill_file"
            sed -i 's|OPSX: |OSC: |g' "$skill_file"
        done < <(find "$target_dir/skills" -type f -name "*.md" -print0 2>/dev/null)
    fi
    
    if [[ $renamed -gt 0 ]]; then
        log_success "Renamed $renamed core resource(s)"
    fi
}

deploy_core() {
    local tool="$1"
    local target_dir
    target_dir=$(get_tool_dir "$tool")
    local target_manifest="$(pwd)/$target_dir/manifest.json"
    
    if ! command -v openspec &>/dev/null; then
        log_error "openspec CLI not found. Install it first:"
        echo "  npm install -g @fission-ai/openspec"
        return 1
    fi
    
    log_info "Delegating to openspec CLI for core resources..."
    
    local output
    if output=$(openspec init --tools "$tool" --force 2>&1); then
        rename_core_resources "$tool"
        log_success "Core resources installed (osc-*)"
        
        local core_version
        core_version=$(openspec --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "unknown")
        
        if [[ -f "$target_manifest" ]]; then
            local tmp_manifest="${target_manifest}.tmp"
            jq --arg v "$core_version" '.core = {"version": $v, "installed": true}' \
                "$target_manifest" > "$tmp_manifest" && mv "$tmp_manifest" "$target_manifest"
            log_info "Core v$core_version tracked in manifest"
        fi
    else
        log_error "openspec init failed"
        echo "$output" >&2
        return 1
    fi
}

run_auto() {
    local script_path="$(pwd)/.opencode/scripts/osx-orchestrate"
    
    if [[ ! -f "$script_path" ]]; then
        log_error "osx-orchestrate not found"
        log_error "Run: $SCRIPT_NAME install opencode"
        exit 1
    fi
    
    exec "$script_path" "$@"
}

validate_deployment() {
    local target_dir="$1" manifest="$2"
    local warnings=0
    
    if [[ ! -d "$target_dir" ]]; then
        return 0
    fi
    
    local types
    types=$(echo "$manifest" | jq -r '.resources | keys[]' 2>/dev/null || true)
    
    for type in $types; do
        local names
        names=$(echo "$manifest" | jq -r ".resources.$type | keys[]" 2>/dev/null || true)
        
        for name in $names; do
            local found=false
            
            case "$type" in
                skills)
                    [[ -d "$target_dir/skills/$name" ]] && found=true
                    ;;
                agents)
                    [[ -f "$target_dir/agents/${name}.md" ]] && found=true
                    ;;
                commands)
                    if [[ -f "$target_dir/commands/${name}.md" ]]; then
                        found=true
                    else
                        local base_name="${name#osx-}"
                        for subdir in "$target_dir/commands"/*/; do
                            if [[ -f "$subdir${base_name}.md" ]]; then
                                found=true
                                break
                            fi
                        done
                    fi
                    ;;
                scripts)
                    [[ -f "$target_dir/scripts/$name" ]] && found=true
                    ;;
                lib)
                    [[ -f "$target_dir/scripts/lib/$name" ]] && found=true
                    ;;
            esac
            
            if [[ "$found" == "false" ]]; then
                log_warn "Resource '$name' in manifest but not deployed"
                warnings=$((warnings + 1))
            fi
        done
    done
    
    if [[ $warnings -gt 0 ]]; then
        echo "  Validation: $warnings warning(s)"
    fi
}

main() {
    if [[ $# -eq 0 ]]; then
        show_usage
        exit 1
    fi
    
    case "$1" in
        --version|-V)
            show_version
            exit 0
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        run)
            shift
            run_auto "$@"
            ;;
    esac
    
    if [[ $# -lt 2 ]]; then
        show_usage
        exit 1
    fi
    
    local command="$1"
    local tool="$2"
    local with_core=false
    local force=false
    
    shift 2
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --with-core)
                with_core=true
                shift
                ;;
            *)
                log_error "Unknown option: $1"
                show_usage
                exit 1
                ;;
        esac
    done
    
    if [[ "$command" != "install" ]] && [[ "$command" != "update" ]]; then
        log_error "Unknown command: $command"
        echo
        echo "Available commands: install, update"
        show_usage
        exit 1
    fi
    
    if [[ "$command" == "update" ]]; then
        force=true
    fi
    
    TARGET_DIR=$(get_tool_dir "$tool") || {
        log_error "Unknown tool: $tool"
        echo "  Available tools: opencode, claude"
        exit 1
    }
    TOOL="$tool"
    
    resolve_resources_dir
    
    deploy_all_resources "$tool" "$force"
    
    if [[ -f "$(pwd)/$TARGET_DIR/scripts/osx-orchestrate" ]]; then
        update_gitignore
    fi
    
    if [[ "$with_core" == "true" ]]; then
        deploy_core "$tool"
    fi
    
    local source_manifest="$RESOURCES_DIR/$tool/manifest.json"
    if [[ -f "$source_manifest" ]]; then
        validate_deployment "$(pwd)/$TARGET_DIR" "$(cat "$source_manifest")"
    fi
}

main "$@"
