#!/usr/bin/env bash
# Verify version bump when versioned files are modified.
# Run via: mise run version:check
#
# Scope: framework components (resources/*/manifest.toml entries) and
# install.sh (independent installer version). The three tool-version
# files (source/cli.py, source/__init__.py, pyproject.toml) are owned
# by `mise run release` and are intentionally not checked here.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/manifest.sh
source "$SCRIPT_DIR/lib/manifest.sh"
# shellcheck source=lib/detect.sh
source "$SCRIPT_DIR/lib/detect.sh"
# shellcheck source=lib/state.sh
source "$SCRIPT_DIR/lib/state.sh"

# Global accumulator; we build it with jq one entry at a time.
FILES_JSON="[]"

get_staged_files() {
    git diff --cached --name-only --diff-filter=ACMR -- \
        "resources/*/skills/*/SKILL.md" \
        "resources/*/skills/*/references/*.md" \
        "resources/*/skills/*/scripts/*" \
        "resources/*/agents/*.md" \
        "resources/*/commands/*.md" \
        "resources/*/commands/*/*.md" 2>/dev/null \
        | grep -v "/AGENTS\.md$" || true
}

get_script_files() {
    git diff --cached --name-only --diff-filter=ACMR -- \
        "install.sh" 2>/dev/null || true
}

# Extract the SCRIPT_VERSION value from a script file.
# Handles both `SCRIPT_VERSION = "x"` (Python) and `SCRIPT_VERSION="x"` (bash).
get_script_version_from_file() {
    local file_path="$1"
    [[ -f "$file_path" ]] || return 1
    grep -E '(readonly[[:space:]]+)?SCRIPT_VERSION[[:space:]]*=' "$file_path" \
        | head -n1 \
        | sed -E 's/^[[:space:]]*(readonly[[:space:]]+)?SCRIPT_VERSION[[:space:]]*=[[:space:]]*"?([^"]*)"?$/\2/'
}

append_entry() {
    FILES_JSON=$(jq --argjson e "$1" '. + [$e]' <<< "$FILES_JSON")
}

check_resource_file() {
    local file_path="$1"
    local resource_info platform resource_type resource_name manifest

    if ! resource_info=$(resource_info_from_path "$file_path"); then
        return 0
    fi
    if ! platform=$(platform_for_path "$file_path"); then
        return 0
    fi

    resource_type="${resource_info%%:*}"
    resource_name="${resource_info##*:}"
    manifest=$(manifest_path_for_platform "$platform")

    if [[ ! -f "$manifest" ]]; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg platform "$platform" \
            --arg rt "$resource_type" \
            --arg rn "$resource_name" \
            '{path:$path, platform:$platform, resource_type:$rt, resource_name:$rn, current_version:"", status:"error", error:("Could not load " + $platform + " manifest")}')"
        return 0
    fi

    local current_version
    current_version=$(get_resource_version "$manifest" "$resource_type" "$resource_name" || true)
    if [[ -z "$current_version" ]]; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg platform "$platform" \
            --arg rt "$resource_type" \
            --arg rn "$resource_name" \
            '{path:$path, platform:$platform, resource_type:$rt, resource_name:$rn, current_version:"", status:"error", error:("Resource \"" + $rn + "\" not found in " + $platform + " manifest")}')"
        return 0
    fi

    if ! validate_semver "$current_version"; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg platform "$platform" \
            --arg rt "$resource_type" \
            --arg rn "$resource_name" \
            --arg v "$current_version" \
            '{path:$path, platform:$platform, resource_type:$rt, resource_name:$rn, current_version:$v, status:"error", error:"Invalid version format"}')"
        return 0
    fi

    # No content change → nothing to bump. The file is staged but the
    # staged content matches HEAD byte-for-byte (e.g. a no-op re-stage
    # or chmod-only change), so no version bump is required.
    local diff_text
    diff_text=$(git diff --cached -- "$file_path" 2>/dev/null || true)
    if [[ -z "$diff_text" ]]; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg platform "$platform" \
            --arg rt "$resource_type" \
            --arg rn "$resource_name" \
            --arg v "$current_version" \
            '{path:$path, platform:$platform, resource_type:$rt, resource_name:$rn, current_version:$v, status:"ok", error:""}')"
        return 0
    fi

    # The version for a resource lives in resources/<platform>/manifest.toml,
    # not in the file itself. Compare the working-tree version to the
    # version in HEAD's manifest: a bump is "done" iff the two differ.
    # `manifest` is an absolute filesystem path; `git show` needs a path
    # relative to the repo root, so strip the project root prefix.
    local repo_root manifest_relpath head_version
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
    if [[ -n "$repo_root" && "$manifest" == "${repo_root}/"* ]]; then
        manifest_relpath="${manifest#"${repo_root}"/}"
    else
        manifest_relpath="$manifest"
    fi
    head_version=$(git show "HEAD:${manifest_relpath}" 2>/dev/null \
        | parse_resource_version_from_stdin "$resource_type" "$resource_name" \
        || true)

    if [[ "$current_version" != "$head_version" ]]; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg platform "$platform" \
            --arg rt "$resource_type" \
            --arg rn "$resource_name" \
            --arg v "$current_version" \
            '{path:$path, platform:$platform, resource_type:$rt, resource_name:$rn, current_version:$v, status:"ok", error:""}')"
    else
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg platform "$platform" \
            --arg rt "$resource_type" \
            --arg rn "$resource_name" \
            --arg v "$current_version" \
            '{path:$path, platform:$platform, resource_type:$rt, resource_name:$rn, current_version:$v, status:"needs_bump", error:""}')"
    fi
}

# Check a single install.sh file. The installer tracks its own SCRIPT_VERSION
# independent of the project tool version; this is the only "script" file in
# scope here. The three tool-version files (source/cli.py, source/__init__.py,
# pyproject.toml) are owned by `mise run release`.
check_script_file() {
    local file_path="$1"
    local current_version

    if ! current_version=$(get_script_version_from_file "$file_path"); then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg rn "$(basename "$file_path")" \
            '{path:$path, platform:"root", resource_type:"scripts", resource_name:$rn, current_version:"", status:"error", error:"SCRIPT_VERSION not found"}')"
        return 0
    fi

    if ! validate_semver "$current_version"; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg rn "$(basename "$file_path")" \
            --arg v "$current_version" \
            '{path:$path, platform:"root", resource_type:"scripts", resource_name:$rn, current_version:$v, status:"error", error:"SCRIPT_VERSION has invalid version format"}')"
        return 0
    fi

    local diff_text
    diff_text=$(git diff --cached -- "$file_path" 2>/dev/null || true)
    if [[ -z "$diff_text" ]]; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg rn "$(basename "$file_path")" \
            --arg v "$current_version" \
            '{path:$path, platform:"root", resource_type:"scripts", resource_name:$rn, current_version:$v, status:"ok", error:""}')"
        return 0
    fi

    local version_bumped
    version_bumped=$(grep -E '^\+.*SCRIPT_VERSION' <<< "$diff_text" || true)
    if [[ -n "$version_bumped" ]]; then
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg rn "$(basename "$file_path")" \
            --arg v "$current_version" \
            '{path:$path, platform:"root", resource_type:"scripts", resource_name:$rn, current_version:$v, status:"ok", error:""}')"
    else
        append_entry "$(jq -n \
            --arg path "$file_path" \
            --arg rn "$(basename "$file_path")" \
            --arg v "$current_version" \
            '{path:$path, platform:"root", resource_type:"scripts", resource_name:$rn, current_version:$v, status:"needs_bump", error:""}')"
    fi
}

upgrade_needs_bump() {
    local entry="$1"
    local path
    path=$(jq -r '.path' <<< "$entry")
    local bump_type
    bump_type=$(detect_bump_type "$path")
    case "$bump_type" in
        major|minor|patch) jq --arg s "needs_${bump_type}" '.status = $s' <<< "$entry" ;;
        *) jq --arg s "needs_patch" '.status = $s' <<< "$entry" ;;
    esac
}

print_table() {
    printf '\nVersion Bump Required\n'
    printf '=====================\n\n'

    local header
    header=$(printf '%-50s  %-20s  %-10s  %-15s' "File" "Resource" "Current" "Status")
    printf '%s\n' "$header"
    printf '%*s\n' "${#header}" '' | tr ' ' '='

    while IFS= read -r f; do
        local display_path
        display_path=$(jq -r '.path' <<< "$f")
        if (( ${#display_path} > 48 )); then
            display_path="...${display_path: -45}"
        fi
        printf '%-50s  %-20s  %-10s  %-15s\n' \
            "$display_path" \
            "$(jq -r '.resource_name' <<< "$f")" \
            "$(jq -r '.current_version' <<< "$f")" \
            "$(jq -r '.status' <<< "$f")"
    done < <(jq -c '.[]' <<< "$FILES_JSON")

    printf '\nRun: mise run version:update\n'
}

main() {
    local output_format="table"
    if [[ "${1:-}" == "--json" ]]; then
        output_format="json"
    fi

    local f
    while IFS= read -r f; do
        [[ -n "$f" ]] || continue
        check_resource_file "$f"
    done < <(get_staged_files)

    while IFS= read -r f; do
        [[ -n "$f" ]] || continue
        check_script_file "$f"
    done < <(get_script_files)

    # Upgrade needs_bump -> needs_{major|minor|patch} by inspecting the diff.
    local upgraded="[]"
    while IFS= read -r f; do
        local status
        status=$(jq -r '.status' <<< "$f")
        if [[ "$status" == "needs_bump" ]]; then
            f=$(upgrade_needs_bump "$f")
        fi
        upgraded=$(jq --argjson e "$f" '. + [$e]' <<< "$upgraded")
    done < <(jq -c '.[]' <<< "$FILES_JSON")
    FILES_JSON="$upgraded"

    local has_error=0
    while IFS= read -r f; do
        local s
        s=$(jq -r '.status' <<< "$f")
        if [[ "$s" == error* || "$s" == needs_* ]]; then
            has_error=1
            break
        fi
    done < <(jq -c '.[]' <<< "$FILES_JSON")

    local overall_status="ok"
    [[ $has_error -eq 1 ]] && overall_status="error"

    if [[ "$output_format" == "json" ]]; then
        write_version_state "$overall_status" "$FILES_JSON"
        jq -n --arg status "$overall_status" --argjson files "$FILES_JSON" \
            '{status: $status, files: $files}'
    else
        write_version_state "$overall_status" "$FILES_JSON"
        if [[ $has_error -eq 0 ]]; then
            exit 0
        fi
        print_table
    fi

    [[ $has_error -eq 1 ]] && exit 1
    exit 0
}

main "$@"
